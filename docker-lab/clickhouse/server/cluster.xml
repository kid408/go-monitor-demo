<clickhouse>
    <logger>
        <level>information</level>
        <console>true</console>
    </logger>
    <listen_host>0.0.0.0</listen_host>
    <remote_servers>
        <lab_cluster>
            <shard>
                <internal_replication>true</internal_replication>
                <replica>
                    <host>clickhouse-1</host>
                    <port>9000</port>
                    <user>lab</user>
                    <password>lab123</password>
                </replica>
                <replica>
                    <host>clickhouse-2</host>
                    <port>9000</port>
                    <user>lab</user>
                    <password>lab123</password>
                </replica>
            </shard>
        </lab_cluster>
    </remote_servers>
    <zookeeper>
        <node index="1">
            <host>keeper-1</host>
            <port>9181</port>
        </node>
        <node index="2">
            <host>keeper-2</host>
            <port>9181</port>
        </node>
        <node index="3">
            <host>keeper-3</host>
            <port>9181</port>
        </node>
    </zookeeper>
    <distributed_ddl>
        <path>/clickhouse/task_queue/ddl</path>
    </distributed_ddl>
</clickhouse>
